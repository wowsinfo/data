<?xml version="1.0"?>
<constants>
	<enum name="ROUTE_NAME" type="String">
		<const name="CAMPAIGN"				value="campaign"/>
		<const name="CHAPTER_HUB"			value="chapter_hub"/>
	</enum>

	<enum name="CAMPAIGN_TYPE" type="String">
		<const name="COMPOSITION"			value="composition"/>
	</enum>

	<enum name="CAMPAIGN_TAB" type="String">
		<const name="SCENE"					value="scene"/>
		<const name="PROGRESS"				value="progress"/>
	</enum>

	<enum name="SCENE_STYLE" type="String">
		<const name="STATIC"				value="static"/>
		<const name="DYNAMIC"				value="dynamic"/>
	</enum>

	<enum name="ASSET_SOURCE" type="String">
		<const name="COMMON"				value="common"/>
		<const name="CHAPTER"				value="chapter"/>
		<const name="STAGE"					value="stage"/>
	</enum>

	<enum name="NARRATIVE_TYPE" type="String">
		<const name="TEXT"					value="text"/>
		<const name="MODAL_DIALOGUE"		value="modal_dialogue"/>
		<const name="MODAL_IMAGE"			value="modal_image"/>
		<const name="MODAL_VIDEO"			value="modal_video"/>
		<const name="SCENE_IMAGE"			value="scene_image"/>
		<const name="SCENE_VIDEO"			value="scene_video"/>

		<range name="SCENE_TYPES" values="SCENE_IMAGE, SCENE_VIDEO"/>
	</enum>

	<enum name="SCENE_ANIMATION_TYPE" type="String">
		<const name="BLACKFADE"				value="blackfade"/>
		<const name="CROSSFADE"				value="crossfade"/>
		<const name="VIDEO"					value="video"/>
	</enum>
</constants>