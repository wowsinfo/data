<?xml version="1.0"?>
<constants>
	<enum name="HU2D_SIZE_TYPE" type="String">
		<const name="SMALL"		value="small"/>
		<const name="LARGE"		value="large"/>
	</enum>

	<enum name="BANNER_SIDE" type="String">
		<const name="PROMOTED"	value="promoted"/>
		<const name="SIDE"		value="side"/>
		<const name="INFO"		value="info"/>
		<const name="NEWS"		value="news"/>
		<value_to_name/>
		<name_to_value/>

		<range name="IMAGE_REQUIRED"	values="PROMOTED, SIDE"/>
	</enum>

	<enum name="BANNER_MAX_QUANTITY_BY_SIDE" type="Integer">
		<const name="PROMOTED"	value="3"/>
		<const name="SIDE"		value="4"/>
		<const name="INFO"		value="4"/>
		<const name="NEWS"		value="1"/>
		<name_to_value/>
	</enum>

	<enum name="BANNER_TYPE" type="Integer">
		<const name="BASE"					value="0"/>
		<const name="ALL_NEWS"				value="1"/>
		<const name="RECRUITMENT"			value="2"/>
		<const name="NY_GIFT"				value="3"/>
		<const name="LNY_GIFT"				value="4"/>
		<const name="SNOWFLAKES"			value="5"/>
		<const name="ADVENT_CALENDAR"		value="6"/>
		<const name="NEW_YEAR_TREE"			value="7"/>
		<const name="SSE"					value="8"/>
		<const name="BATTLE"				value="9"/>

		<value_to_name/>
		<name_to_value/>
	</enum>

	<enum name="BANNER_TOOLTIP_RENDERER" type="String">
		<const name="BASE"								value="Hub2DStandardTooltip"/>
		<const name="EVENT_BATTLE"						value="EventBattleTypeTooltip"/>
		<const name="COMMON_BATTLE"						value="CommonBattleTypeTooltip"/>
		<const name="HEADER_DESCRIPTION_INSTRUCTION"	value="HeaderDescriptionInstructionTooltip"/>
		<const name="SNOWFLAKES"						value="SnowflakesBannerTooltip"/>
		<const name="SSE"								value="SseBannerTooltip"/>
		<const name="RECRUITMENT"						value="RecruitmentBannerTooltip"/>
		<const name="ALL_NEWS"							value="IngameNewsTooltip"/>

		<value_to_name/>
		<name_to_value/>
	</enum>

</constants>