<?xml version="1.0"?>
<constants>
	<enum name="EXTERIOR_TYPE"			type="Integer">
		<const name="CAMOUFLAGE"		value="0"/>
		<const name="PERMOFLAGE"		value="1"/>
		<const name="SKIN"				value="2"/>
		<const name="MSKIN"				value="3"/>
		<const name="SIGNAL"			value="4"/>
		<const name="SHIP_DESTRUCTION"	value="5"/>
		<const name="VISUAL_CUSTOMIZATION"	value="8"/>
		<value_to_name/>
	</enum>

	<enum name="EXTERIOR_NAMES"				type="String">
			<const name="CAMOUFLAGE"		value="camouflage"/>
			<const name="PERMOFLAGE"		value="permoflage"/>
			<const name="SKIN"				value="skin"/>
			<const name="MSKIN"				value="mskin"/>
			<const name="SIGNAL"			value="flags"/>
			<const name="SHIP_DESTRUCTION"	value="ship_destruction"/>
			<const name="VISUAL_CUSTOMIZATION"	value="visual_customization"/>
	</enum>

	<enum name="CAMO_TYPE"			type="String">
		<const name="PERMANENT"		value="permanent"/>
		<const name="EXPENDABLE"	value="expendable"/>
	</enum>

	<enum name="PERMANENT_CAMO_TYPE"	type="String">
		<const name="UNIQUE"			value="unique"/>
		<const name="TILEFLAGE"			value="tileflage"/>
	</enum>

	<enum name="SHIP_DESTRUCTION_TYPE"	type="String">
		<const name="UNIQUE"			value="unique"/>
		<const name="COMMON"			value="common"/>
		<const name="SINGLE_COLOR"		value="single_color"/>
		<const name="ABSTRACT_PATTERNS"	value="abstract_pattern"/>
		<const name="PAINTWORK"			value="paintwork"/>
		<const name="AWARD"				value="award"/>
		<const name="COLLABORATIVE"		value="collaborative"/>

		<range name="SORT_ORDER"		values="UNIQUE, COMMON, SINGLE_COLOR, ABSTRACT_PATTERNS, PAINTWORK, AWARD, COLLABORATIVE "/>
	</enum>

	<enum name="CAMO_PRICE_GROUP"   type="String">
        <const name="CAMOUFLAGE"    value="CAMOUFLAGE_GROUP"/>
        <const name="TILEFLAGE"     value="TILEFLAGE_GROUP" />
    </enum>

	<enum name="VISUAL_CUSTOMIZATION_NODES_SIDE" type="String">
		<const name="NONE"			value="none"	/>
		<const name="RIGHT"			value="right"	/>
		<const name="LEFT"			value="left"	/>
		<const name="CENTER"		value="center"	/>

		<range name="SORT_ORDER" 	values="RIGHT, LEFT, CENTER"/>
	</enum>

	<enum name="VISUAL_CUSTOMIZATION_NODES_GROUP" type="String">
		<const name="NONE"							value="none"	/>
		<const name="STERN_1"						value="stern_1"	/>
		<const name="HULL_1"						value="hull_1"	/>
		<const name="BOW_1"							value="bow_1"	/>
		<const name="SUPERSTRUCTURE_1"				value="superstructure_1"/>
		<const name="PIPE_1"						value="pipe_1"	/>

		<range name="SORT_ORDER" 	values="STERN_1, HULL_1, BOW_1, SUPERSTRUCTURE_1, PIPE_1"/>
	</enum>

	<enum name="VISUAL_CUSTOMIZATION_SORTING_GROUP" type="String">
		<const name="NATIONS"					value="nations"			/>
		<const name="ARTS"						value="arts"			/>
		<const name="QUOTES"					value="quotes"			/>

		<range name="SORT_ORDER"	values="NATIONS, ARTS, QUOTES"/>
	</enum>
</constants>