<root>
	<Properties>
		<!-- Matchmaker entry state now lives in MatchmakerState/EnqueueContext, not on the
		     component, so no BASE properties are persisted here. -->
	</Properties>

	<BaseMethods>
		<enter>
			<Exposed/>
			<Args>
				<shipID> SHIP_ID </shipID>
				<queueType> QUEUE_TYPE </queueType>
				<mapID> INT16 </mapID>  <!-- MAP_ID (UINT8) or -1 -->
				<gameMode> INT32 </gameMode>  <!-- GAME_MODE (UINT16) or -1 -->
				<operationID> GAMEPARAMS_ID </operationID>
			</Args>
		</enter>
		
		<leave>
			<Exposed/>
		</leave>
		
		<onEnterViaDivision>  <!-- Callback from Division -->
			<Args>
				<enqueueData> ENQUEUE_DATA </enqueueData>
				<requestID> STRING </requestID>
			</Args>
		</onEnterViaDivision>

		<onRedirectedViaDivision>  <!-- Callback from Division -->
			<Args>
				<enqueueData> ENQUEUE_DATA </enqueueData>
				<requestID> STRING </requestID>
			</Args>
		</onRedirectedViaDivision>
		
		<notifyPlayerLeftDivisionMatchmaker>  <!-- Callback from Division -->
			<Args>
				<reason> UINT8 </reason>
			</Args>
		</notifyPlayerLeftDivisionMatchmaker>
	</BaseMethods>
	
	<ClientMethods>
		<onEnter>
			<Args>
				<queueType> QUEUE_TYPE </queueType>
				<shipID> SHIP_ID </shipID>
				<description> PICKLED_BLOB </description>
			</Args>
		</onEnter>
		
		<onQueueInfoReceived>
			<Args>
				<queueType> GAMEPARAMS_ID </queueType>  <!-- QUEUE_TYPE (UINT16) or OPERATION_ID (GAMEPARAMS_ID/UINT32) -->
				<queueInfo> PICKLED_BLOB </queueInfo>
			</Args>
		</onQueueInfoReceived>
		
		<onLeave>
			<Args>
				<reason> UINT8 </reason>
			</Args>
		</onLeave>

		<onBattlePreparationCancelled>
		</onBattlePreparationCancelled>
	</ClientMethods>
	
	<ofEntity>
		<Account/>
	</ofEntity>
</root>
